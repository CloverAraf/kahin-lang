// Kahin System Test Core
ice_aktar zihin

tanimla sistem_kontrol(n):
    yazdir("Sistem Kontrol Noktasi:", zihin.islem_suresi())
    
    veriler = ["stabil", "hizli", "kritik"]
    
    her_biri_icin veri icinde veriler:
        durum = zihin.analiz(veri)
        yazdir("Veri:", veri, "| Durum:", durum)
        
    dondur n * n

tanimla ana_islem():
    sonuc = sistem_kontrol(10)
    yazdir("Islem Tamamlandi. Deger:", sonuc)

ana_islem()
