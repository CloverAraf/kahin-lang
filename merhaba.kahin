// Kahin - Merhaba Dünya

yazdir("═" * 50)
yazdir("🚀 Merhaba Kahin!")
yazdir("Türkçe Programlama Dili")
yazdir("═" * 50)

// Değişkenler
isim = "Ahmet"
dil = "Kahin"

